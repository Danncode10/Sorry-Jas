# Never commit secrets or API keys!
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ---- Vercel ----
.vercel

# ---- Debug Logs ----
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ---- OS Files ----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ---- Editor / IDE ----
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ---- TypeScript ----
*.tsbuildinfo
next-env.d.ts

# ---- Testing ----
/coverage
/.nyc_output

# ---- Misc ----
*.pem
.cache/
